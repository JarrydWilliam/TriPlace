# Dependencies
node_modules/
.pnpm-debug.log*

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
.next/
out/

# Development files (exclude from deployment)
dev/
attached_assets/

# Cache directories
.cache/
.local/
.config/
.upm/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# ESLint cache
.eslintcache

# TypeScript cache
*.tsbuildinfo

# Temporary folders
tmp/
temp/

# Android signing keystore (store separately in Codemagic secrets)
*.jks
*.keystore
*-keystore-base64.txt

# Capacitor: commit native platform folders so Codemagic CI can build them
# ios/ and android/ are intentionally tracked in git
# Only ignore generated/build artifacts inside them (covered by ios/.gitignore)
.vercel
.env*

# TLS private keys — never commit to git
*.pem
*.key
cert_key.pem
