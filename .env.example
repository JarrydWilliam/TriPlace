# SameVibe — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Add all variables to Vercel dashboard + Codemagic env groups.

# ── Firebase (Client-side — safe to expose in bundle) ─────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ── OpenAI (Server-side only — NEVER expose to client) ────────────────────────
OPENAI_API_KEY=sk-...your_openai_key_here

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Admin (Server-side only — NEVER expose to client) ─────────────────────────
# Used by requireAdmin middleware to protect admin-only routes.
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=your_strong_random_secret_here

# ── RevenueCat (Native iOS/Android only) ──────────────────────────────────────
# Get from RevenueCat dashboard → Apps → API Keys → Public App Key
# Do NOT use the test key (test_...) in production.
VITE_REVENUECAT_API_KEY=appl_your_live_key_here

# ── Admin Email (Frontend guard for /admin/metrics route) ─────────────────────
VITE_ADMIN_EMAIL=your_admin_email@example.com

# ── App Version (Shown in Settings > Support > App Information) ───────────────
VITE_APP_VERSION=1.0.0

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Optional: Event API Keys (event-scraper.ts) ───────────────────────────────
# These silently return empty results if not set (graceful degradation).
# EVENTBRITE_API_KEY=your_eventbrite_key
# TICKETMASTER_API_KEY=your_ticketmaster_key
# MEETUP_API_KEY=your_meetup_key
# SEATGEEK_API_KEY=your_seatgeek_key

# ── Optional: Push Notifications (FCM Server Key) ─────────────────────────────
# FCM_SERVER_KEY=your_fcm_server_key

# ── Notes ─────────────────────────────────────────────────────────────────────
# For Codemagic CI, add all of these as Environment Variables in the
# Codemagic dashboard under App Settings > Environment variables.
# iOS builds also need: APPLE_ID, APP_SPECIFIC_PASSWORD, TEAM_ID
# Android builds need: KEYSTORE_BASE64, KEY_ALIAS, KEY_PASSWORD, STORE_PASSWORD
#
# IMPORTANT: Rotate any key that has ever been committed to git history.
# Use `git log --all -S "sk-proj"` to check if secrets are in history.
